# =====================================================================
# КБЖУЙ — GigaChat configuration template
#
# Скопируй этот файл в .env.gigachat (он в .gitignore — не попадёт на GitHub)
# и впиши СВОИ креды от GigaChat. Креды автора в репозиторий не загружены.
#
# Где взять:
# 1. https://developers.sber.ru/studio
# 2. GigaChat API → Settings → Authorization
# 3. Скопируй значение в KBZHUY_GIGACHAT_CREDENTIALS ниже
#
# Без своих кредов: чат-агент будет работать на SimpleAgent (правила,
# без LLM) — приложение функционирует полностью кроме умного чата.
# =====================================================================

# Включить агента (true / false)
KBZHUY_USE_GIGACHAT=false

# Base64-строка из Sber Studio (Authorization header)
KBZHUY_GIGACHAT_CREDENTIALS=

# Модель: GigaChat-Pro (с function-calling) или GigaChat (без tools, дешевле)
KBZHUY_GIGACHAT_MODEL=GigaChat-Pro
