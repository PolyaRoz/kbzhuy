# =====================================================================
# КБЖУЙ — backend configuration template
#
# Copy this file to backend/.env and fill in the values for local dev.
# All variables are read with the KBZHUY_ prefix (see app/core/config.py).
# =====================================================================

# --- Core ---
KBZHUY_DEBUG=true
KBZHUY_SECRET_KEY=change-me-to-a-random-string-min-32-chars

# --- Database & cache ---
# When running via docker compose these are provided automatically.
# These defaults are for running uvicorn outside Docker against the
# Docker-compose db/redis services.
KBZHUY_DATABASE_URL=postgresql+asyncpg://kbzhuy:kbzhuy@localhost:5432/kbzhuy
KBZHUY_REDIS_URL=redis://localhost:6379/0

# --- AI agent ---
# Get a key from https://console.anthropic.com/ — optional for the MVP
# (the app falls back to deterministic responses without it).
KBZHUY_ANTHROPIC_API_KEY=
KBZHUY_AI_MODEL=claude-sonnet-4-6

# --- Local LLM fallback (optional) ---
# Point to a self-hosted Ollama / LM Studio instance.
KBZHUY_USE_LOCAL_LLM=false
KBZHUY_LOCAL_LLM_URL=http://host.docker.internal:11434/v1
KBZHUY_LOCAL_LLM_MODEL=qwen2.5:14b
